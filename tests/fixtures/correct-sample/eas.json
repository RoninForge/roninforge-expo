{
  "cli": {
    "version": ">= 18.13.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "API_BASE": "http://localhost:3000"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "API_BASE": "https://staging-api.example.com"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "API_BASE": "https://api.example.com"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
